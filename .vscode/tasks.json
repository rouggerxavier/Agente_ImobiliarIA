{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Uvicorn",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--access-log",
        "--log-level",
        "info",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers",
        "clear": true
      }
    },
    {
      "label": "Frontend: Vite",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers",
        "clear": true
      }
    },
    {
      "label": "Dev: Uvicorn + Frontend",
      "dependsOn": [
        "Backend: Uvicorn",
        "Frontend: Vite"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
