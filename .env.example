# =========================
# App / API
# =========================
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000

# Comma-separated origins for CORS
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Protects POST /webhook via X-API-Key
WEBHOOK_API_KEY=

# =========================
# Agent behavior
# =========================
USE_LLM=true
TRIAGE_ONLY=true
QUESTION_SEED=

# LLM timeout in seconds
LLM_TIMEOUT=120

# =========================
# Knowledge / RAG
# =========================
# If empty, layer 2 will only use lexical retrieval.
# If set to true and OPENAI_API_KEY exists, hybrid lexical+embeddings is enabled.
KNOWLEDGE_EMBEDDINGS_ENABLED=true
KNOWLEDGE_EMBED_MODEL=text-embedding-3-small
KNOWLEDGE_EMBED_CACHE_PATH=data/knowledge_embeddings_cache.json

# Hybrid score weights (normalized internally)
KNOWLEDGE_LEXICAL_WEIGHT=0.65
KNOWLEDGE_SEMANTIC_WEIGHT=0.35
KNOWLEDGE_SEMANTIC_CANDIDATES=120

# =========================
# LLM providers (priority in code)
# 1) GEMINI_API_KEY
# 2) OPENAI_API_KEY
# 3) GROQ_API_KEY
# =========================

# Google Gemini (recommended)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / OpenRouter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional knobs for local OpenAI-compatible servers (e.g., Ollama)
LLM_KEEP_ALIVE=
LLM_NUM_CTX=0
LLM_NUM_THREADS=0
LLM_USE_MMAP=true
LLM_PREWARM=false

# =========================
# Persistence / Files
# =========================
LEADS_LOG_PATH=data/leads.jsonl
LEADS_INDEX_PATH=data/leads_index.json
EVENTS_PATH=data/events.jsonl
ROUTING_LOG_PATH=data/routing_log.jsonl
FOLLOWUP_META_PATH=data/followups.jsonl
PERSIST_RAW_TEXT=false

# Expose real assigned agent contact in output payload (not recommended)
EXPOSE_AGENT_CONTACT=false

# =========================
# SLA thresholds
# =========================
SLA_HOT_THRESHOLD=80
SLA_WARM_THRESHOLD=50

# =========================
# WhatsApp Cloud API
# =========================

# true = do not send real WhatsApp messages
DISABLE_WHATSAPP_SEND=true

# Required for GET /webhook/whatsapp verification
WHATSAPP_VERIFY_TOKEN=

# If empty, signature validation is skipped in POST /webhook/whatsapp
WHATSAPP_APP_SECRET=

# Required only when DISABLE_WHATSAPP_SEND=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# =========================
# Local CLI helper
# =========================
BACKEND_URL=http://localhost:8000

# =========================
# Frontend (Vite build-time env)
# =========================
VITE_BACKEND_URL=http://localhost:8000
VITE_BACKEND_API_KEY=
