# ===== Ambiente =====
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000

# ===== Segurança =====
# Opcional em dev local. Se preencher aqui, envie no frontend em VITE_BACKEND_API_KEY.
WEBHOOK_API_KEY=

# ===== Frontend local =====
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8501,http://127.0.0.1:8501

# ===== Agente/LLM =====
USE_LLM=true
TRIAGE_ONLY=true
LLM_TIMEOUT=120

# Google Gemini (SDK nativo recomendado)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq (opcional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ===== Persistência =====
LEADS_LOG_PATH=data/leads.jsonl
EXPOSE_AGENT_CONTACT=false

# ===== WhatsApp (não necessário para front local) =====
DISABLE_WHATSAPP_SEND=true
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
